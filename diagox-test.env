# Runtime config for diagox-test.yaml.
# Load with your preferred env loader, or export these before starting diagox.

CONF_FILE=diagox-test.yaml

# SIP/WebRTC advertised addresses.
SIP_HOSTNAME=example.local
SIP_BIND_IP=0.0.0.0
SIP_EXTERNAL_HOST=pbx.example.com
SIP_EXTERNAL_MEDIA_IP=203.0.113.10

# Internal SIP server/trunk placeholders used by diagox-test.yaml.
INTERNAL_SIP_CIDR=10.10.0.10/32
INTERNAL_SIP_HOST=10.10.0.10
INTERNAL_SIP_PORT=5060

# Optional external Bearer token auth provider.
# Leave URL empty to use Digest auth only for configured user endpoints.
SIP_REGISTER_BEARER_AUTH_URL=
SIP_REGISTER_BEARER_AUTH_TIMEOUT=2s
SIP_REGISTER_BEARER_AUTH_IDENTITY_FIELD=.sub
SIP_REGISTER_BEARER_AUTH_ACTIVE_FIELD=.active
SIP_REGISTER_BEARER_AUTH_HEADER=

# Useful local toggles.
SIP_DEBUG=false
RTP_DEBUG=false
RTCP_DEBUG=false
CDR_ENABLE=false
FRONTEND_ENABLE=true
