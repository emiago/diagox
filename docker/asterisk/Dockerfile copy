FROM debian

RUN apt update && apt install -y curl 

RUN curl -O http://downloads.asterisk.org/pub/telephony/asterisk/asterisk-20-current.tar.gz \
    && tar xvf asterisk-20-current.tar.gz \
    && mv asterisk-20*/ asterisk \
    && cd asterisk && ls -l 

WORKDIR asterisk
ENV DEBIAN_FRONTEND=noninteractive
RUN ./contrib/scripts/install_prereq install

RUN ./configure --with-pjproject-bundled --with-jansson-bundled 

# https://github.com/dec0dOS/asterisk-docker/blob/master/Dockerfile
